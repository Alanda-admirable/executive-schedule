// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Executive {
  id        String     @id @default(uuid())
  name      String
  title     String
  imageUrl  String?
  color     String     @default("#64748b")
  order     Int        @default(0)
  schedules Schedule[]
}

model DayTheme {
  dayIndex  Int      @id // 0 for Sunday, 1 for Monday, etc.
  dayName   String
  bg        String
  soft      String
  ink       String
  border    String
}

model Schedule {
  id          String    @id @default(uuid())
  executiveId String
  executive   Executive @relation(fields: [executiveId], references: [id])
  date        DateTime
  startTime   String    // Storing as string "HH:mm" for easier display/input
  endTime     String?   // Optional end time
  mission     String
  location    String
  agency      String
  dressCode   String?
  status      String    @default("ACTIVE") // ACTIVE, DRAFT
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([date])
}
